{
  "name": "repo-to-content",
  "version": "0.1.0",
  "description": "Generate evidence-grounded launch content from local repository facts",
  "type": "module",
  "bin": {
    "repo-to-content": "src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js test/*.test.js",
    "build": "node scripts/validate.js",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "agent-skill",
    "dry-run",
    "cli",
    "oss"
  ],
  "license": "MIT",
  "files": [
    "src",
    "docs",
    "fixtures",
    "scripts",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-to-content.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-to-content/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-to-content#readme",
  "author": "Roger Chappel"
}
